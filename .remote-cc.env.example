# Remote CC 配置文件
# 运行 'ccc setup' 自动生成，或手动复制:
# cp .remote-cc.env.example .remote-cc.env

# VPS SSH 地址（必填）
REMOTE_CC_HOST=root@your-vps-ip

# SSH 端口（可选，默认 22）
# REMOTE_CC_SSH_PORT=22

# SSH 私钥路径（高级可选；默认走本机 ssh/config/agent）
# REMOTE_CC_SSH_KEY=~/.ssh/id_ed25519

# MCP Bridge 端口（可选，默认 3100）
# REMOTE_CC_PORT=3100

# 持久化隧道固定端口（可选）
# Bridge 在云端的固定端口（默认 43100）
# REMOTE_CC_TUNNEL_BRIDGE_PORT=43100
# MCP 代理在云端的固定端口起始值（默认 43800，依次 +1）
# REMOTE_CC_TUNNEL_PROXY_BASE_PORT=43800
# 隧道状态文件路径（默认 /tmp/remote-cc-tunnel.json）
# REMOTE_CC_TUNNEL_STATE_FILE=/tmp/remote-cc-tunnel.json

# MCP Bridge 监听地址（建议保持 127.0.0.1）
# MCP_HOST=127.0.0.1

# 本地允许访问的目录（可选，逗号分隔）
# REMOTE_CC_ROOTS=~/projects,~/Desktop,~/Documents

# 远端 workspace 模式（可选）
# project: 同一本地目录复用同一个云端 workspace，便于 /resume（默认）
# session: 每次连接创建独立云端 workspace
# REMOTE_CC_WORKSPACE_MODE=project

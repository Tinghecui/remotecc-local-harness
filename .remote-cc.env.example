# Remote CC 配置文件
# 复制此文件为 .remote-cc.env 并填入你的配置
# cp .remote-cc.env.example .remote-cc.env

# VPS SSH 地址（必填）
REMOTE_CC_HOST=root@your-vps-ip

# MCP Bridge 端口（可选，默认 3100）
# REMOTE_CC_PORT=3100

# connect.sh 在云端自动分配会话端口的范围（可选）
# REMOTE_CC_REMOTE_PORT_START=43000
# REMOTE_CC_REMOTE_PORT_END=48999

# MCP Bridge 监听地址（建议保持 127.0.0.1）
# MCP_HOST=127.0.0.1

# 本地允许访问的目录（可选，逗号分隔）
# REMOTE_CC_ROOTS=~/projects,~/Desktop,~/Documents
